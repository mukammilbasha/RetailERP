<?xml version="1.0" encoding="utf-8"?>
<!-- RetailERP Frontend — IIS web.config (iisnode + Next.js standalone) -->
<configuration>
  <system.webServer>

    <handlers>
      <add name="iisnode" path="server.js" verb="*" modules="iisnode" />
    </handlers>

    <rewrite>
      <rules>
        <!-- Next.js static assets (_next/static) -->
        <rule name="NextStatic" stopProcessing="true">
          <match url="^_next/static/(.+)$" />
          <action type="Rewrite" url=".next/static/{R:1}" />
        </rule>
        <!-- Public folder files -->
        <rule name="PublicFiles" stopProcessing="true">
          <match url="^(favicon\.ico|robots\.txt|manifest\.json|sw\.js|.*\.(png|jpg|jpeg|svg|ico|webp|woff|woff2|ttf|eot))$" />
          <action type="Rewrite" url="public/{R:0}" />
        </rule>
        <!-- All other requests → Next.js server -->
        <rule name="NextApp">
          <match url=".*" />
          <conditions>
            <add input="{REQUEST_FILENAME}" matchType="IsFile" negate="true" />
          </conditions>
          <action type="Rewrite" url="server.js" />
        </rule>
      </rules>
    </rewrite>

    <iisnode
      nodeProcessCommandLine="node"
      loggingEnabled="true"
      logDirectory="logs\iisnode"
      debuggingEnabled="false"
      maxConcurrentRequestsPerProcess="1024"
      maxNamedPipeConnectionRetry="100"
      namedPipeConnectionRetryDelay="250"
      watchedFiles="server.js"
    />

    <staticContent>
      <clientCache cacheControlMode="UseMaxAge" cacheControlMaxAge="365.00:00:00" />
    </staticContent>

    <urlCompression doStaticCompression="true" doDynamicCompression="true" />

    <httpProtocol>
      <customHeaders>
        <remove name="X-Powered-By" />
        <add name="X-Frame-Options" value="DENY" />
        <add name="X-Content-Type-Options" value="nosniff" />
        <add name="X-XSS-Protection" value="1; mode=block" />
        <add name="Referrer-Policy" value="strict-origin-when-cross-origin" />
      </customHeaders>
    </httpProtocol>

    <security>
      <requestFiltering removeServerHeader="true">
        <requestLimits maxAllowedContentLength="52428800" />
      </requestFiltering>
    </security>

  </system.webServer>

  <appSettings>
    <add key="PORT" value="3003" />
    <add key="NODE_ENV" value="production" />
    <add key="NEXT_TELEMETRY_DISABLED" value="1" />
    <add key="NEXT_PUBLIC_API_URL" value="http://localhost:5000" />
  </appSettings>
</configuration>
