{
  "ASPNETCORE_ENVIRONMENT": "QA",
  "ConnectionStrings": {
    "DefaultConnection": "Server=sqlserver;Database=RetailERP;User Id=sa;Password=#{SA_PASSWORD}#;TrustServerCertificate=true"
  },
  "Jwt": {
    "Secret": "#{Jwt__Secret}#",
    "Issuer": "RetailERP.Auth",
    "Audience": "RetailERP.Client",
    "ExpiryMinutes": 240
  },
  "Redis": {
    "ConnectionString": "redis:6379",
    "InstanceName": "RetailERP_QA"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft": "Warning"
    }
  },
  "FeatureFlags": {
    "EnableAuditLog": true,
    "EnableCaching": true,
    "EnableDetailedErrors": true
  }
}
