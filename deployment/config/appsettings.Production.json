{
  "ASPNETCORE_ENVIRONMENT": "Production",
  "ConnectionStrings": {
    "DefaultConnection": "#{ConnectionStrings__DefaultConnection}#"
  },
  "Jwt": {
    "Secret": "#{Jwt__Secret}#",
    "Issuer": "RetailERP.Auth",
    "Audience": "RetailERP.Client",
    "ExpiryMinutes": 60
  },
  "Redis": {
    "ConnectionString": "#{Redis__ConnectionString}#",
    "InstanceName": "RetailERP_Prod"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Warning",
      "Microsoft": "Warning",
      "Microsoft.Hosting.Lifetime": "Information"
    }
  },
  "FeatureFlags": {
    "EnableAuditLog": true,
    "EnableCaching": true,
    "EnableDetailedErrors": false
  }
}
